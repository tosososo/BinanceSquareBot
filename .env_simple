# BinanceSquareBot 环境配置示例
# 复制此文件为 .env 并填写你的配置

# 币安API密钥列表，JSON数组格式
# 支持多账号，每个账号会遍历所有新闻发布推文
BINANCE_API_KEYS=["your-binance-api-key-1", "your-binance-api-key-2"]

# OpenAI API Key (用于LLM生成推文)
LLM_API_KEY=your-openai-api-key

# LLM 模型名称 (可选，默认 gpt-4o-mini)
# LLM_MODEL=gpt-4o-mini

# LLM API 地址 (可选，默认 https://api.openai.com/v1)
# 可配置为其他兼容OpenAI格式的API端点
# LLM_BASE_URL=https://api.openai.com/v1

# SQLite数据库文件路径 (可选，默认 data/processed_urls.db)
# SQLITE_DB_PATH=data/processed_urls.db

# 生成配置 (可选)
# MAX_RETRIES=3          # 生成失败最大重试次数
# MIN_CHARS=101          # 推文最小字符数
# MAX_CHARS=799          # 推文最大字符数
# MAX_HASHTAGS=2         # 最大话题标签数量 (#)
# MAX_MENTIONS=2         # 最大代币标签数量 ($)

# 发布限制 (可选)
# DAILY_MAX_POSTS=100                # 每个账号每天最大发布数量
# PUBLISH_INTERVAL_SECONDS=10.0      # 单账号连续两篇推文发布间隔（秒），避免发布太快
# MAX_CONCURRENT_ACCOUNTS=3          # 最大并发账号数
